---
import type { TocSection } from "../utils/toc";

interface Props {
  tocSections: TocSection[];
  title?: string;
}

const { tocSections, title = "On this page" } = Astro.props;
---

<aside class="hidden lg:block" aria-label={title}>
  <div class="surface-card sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto p-4">
    <p class="font-sans text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-faint">
      {title}
    </p>
    <ol class="mt-4 space-y-4 list-none">
      {tocSections.map((section, sectionIndex) => (
        <li>
          <a
            href={`#${section.heading.slug}`}
            class="block text-sm font-sans font-medium text-ink transition-colors hover:text-accent"
          >
            {sectionIndex + 1}. {section.heading.text}
          </a>
          {section.children.length > 0 && (
            <ol class="mt-2 space-y-1 pl-3 list-none">
              {section.children.map((child) => (
                <li>
                  <a
                    href={`#${child.slug}`}
                    class="text-xs font-sans uppercase tracking-[0.14em] text-ink-faint transition-colors hover:text-accent"
                  >
                    {child.text}
                  </a>
                </li>
              ))}
            </ol>
          )}
        </li>
      ))}
    </ol>
  </div>
</aside>
