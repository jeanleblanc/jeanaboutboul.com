<div class="not-prose project-2048-line-explorer surface-card" data-line-explorer>
  <div class="project-2048-line-explorer__header">
    <p class="kicker">Interactive Element</p>
    <h3>Explorateur de ligne pré-calculée</h3>
    <p>
      Cette petite interface reprend la logique de déplacement vers la gauche
      utilisée dans le moteur. Elle montre le résultat d’une ligne, le score de
      fusion obtenu, et si le cas est couvert par le cache pré-calculé.
    </p>
  </div>

  <div class="project-2048-line-explorer__body">
    <div class="project-2048-line-explorer__presets">
      <button type="button" data-line="2,0,2,4">2, 0, 2, 4</button>
      <button type="button" data-line="4,4,8,0">4, 4, 8, 0</button>
      <button type="button" data-line="2,2,2,2">2, 2, 2, 2</button>
      <button type="button" data-line="1024,1024,0,2">1024, 1024, 0, 2</button>
    </div>

    <div class="project-2048-line-explorer__grid">
      <section>
        <p>Entrée</p>
        <div class="project-2048-line-explorer__cells" data-input-line></div>
      </section>

      <section>
        <p>Sortie après déplacement gauche</p>
        <div class="project-2048-line-explorer__cells" data-output-line></div>
      </section>
    </div>

    <dl class="project-2048-line-explorer__stats">
      <div>
        <dt>Score gagné</dt>
        <dd data-merge-score>0</dd>
      </div>
      <div>
        <dt>Ligne modifiée</dt>
        <dd data-changed>Non</dd>
      </div>
      <div>
        <dt>Cache utilisé</dt>
        <dd data-from-cache>Oui</dd>
      </div>
    </dl>
  </div>
</div>

<script>
  import { simulateLeftLine } from "../../lib/ai2048-browser.js";

  function renderCells(container, values) {
    container.innerHTML = values
      .map((value) => `<span>${value === 0 ? "·" : value}</span>`)
      .join("");
  }

  function initLineExplorer(root) {
    if (!root || root.dataset.ready === "true") {
      return;
    }

    root.dataset.ready = "true";

    const inputLineElement = root.querySelector("[data-input-line]");
    const outputLineElement = root.querySelector("[data-output-line]");
    const mergeScoreElement = root.querySelector("[data-merge-score]");
    const changedElement = root.querySelector("[data-changed]");
    const fromCacheElement = root.querySelector("[data-from-cache]");
    const presetButtons = [...root.querySelectorAll("[data-line]")];

    function update(line) {
      const result = simulateLeftLine(line);
      renderCells(inputLineElement, line);
      renderCells(outputLineElement, result.line);
      mergeScoreElement.textContent = String(result.mergedScore);
      changedElement.textContent = result.changed ? "Oui" : "Non";
      fromCacheElement.textContent = result.fromCache ? "Oui" : "Non";

      presetButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.line === line.join(","));
      });
    }

    presetButtons.forEach((button) => {
      button.addEventListener("click", () => {
        update(button.dataset.line.split(",").map((value) => Number(value)));
      });
    });

    update([2, 0, 2, 4]);
  }

  function bootLineExplorers() {
    document.querySelectorAll("[data-line-explorer]").forEach(initLineExplorer);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootLineExplorers, { once: true });
  } else {
    bootLineExplorers();
  }
</script>

