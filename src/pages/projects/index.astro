---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const imageModules = import.meta.glob("/src/content/images/**/*.{png,jpg,jpeg,webp,svg}", {
  eager: true,
});

function resolveThumbnail(thumbnail?: string): string | undefined {
  if (!thumbnail) return undefined;
  if (thumbnail.startsWith("src/")) {
    const localPath = `/${thumbnail}`;
    const module = imageModules[localPath] as
      | { default?: string | { src?: string } }
      | undefined;
    const imported = module?.default;
    if (typeof imported === "string") return imported;
    if (imported && typeof imported === "object" && "src" in imported) {
      return imported.src;
    }
    return undefined;
  }
  return thumbnail;
}
---

<Layout title="Projects" description="Research projects and experiments">
  <section class="max-w-6xl">
    <h1 class="page-title">Projects</h1>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => {
        const thumbnail = resolveThumbnail(project.data.thumbnail);
        return (
          <a
            href={`/projects/${project.id}`}
            class="surface-card group block overflow-hidden transition-colors hover:border-line-strong"
          >
            <div class="flex aspect-[4/3] items-center justify-center bg-paper-subtle p-5">
              {thumbnail ? (
                <img
                  src={thumbnail}
                  alt={project.data.title}
                  class="h-full w-full object-contain"
                />
              ) : (
                <span class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
                  No preview
                </span>
              )}
            </div>

            <div class="p-5">
              <time class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
                {project.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                })}
              </time>

              <h2 class="mt-3 text-2xl font-bold tracking-tight text-ink">
                {project.data.title}
              </h2>

              <p class="mt-4 font-sans text-[0.68rem] uppercase tracking-[0.16em] text-ink-faint">
                {project.data.tags.join(" · ")}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
