---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Projects" description="Research projects and experiments">
  <h1 class="font-sans text-3xl font-bold tracking-tight text-gray-900 dark:text-dark-text mb-2">
    Projects
  </h1>
  <p class="text-gray-600 dark:text-dark-muted mb-10">
    Research projects, experiments, and engineering work.
  </p>

  <div class="grid gap-6 sm:grid-cols-2">
    {projects.map((project) => (
      <a
        href={`/projects/${project.id}`}
        class="group block overflow-hidden rounded-xl border border-surface-secondary
               bg-white shadow-sm transition-all hover:shadow-md hover:border-nord-frost1/30
               dark:border-dark-card dark:bg-dark-secondary dark:hover:border-nord-frost1/30"
      >
        {/* Thumbnail */}
        <div class="aspect-[16/9] bg-gradient-to-br from-nord-frost1/20 via-nord-frost3/10 to-nord-green/10
                    dark:from-nord-frost1/10 dark:via-nord-frost3/5 dark:to-nord-green/5
                    flex items-center justify-center">
          {project.data.thumbnail ? (
            <img
              src={project.data.thumbnail}
              alt={project.data.title}
              class="h-full w-full object-cover"
            />
          ) : (
            <svg class="h-12 w-12 text-nord-frost1/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          )}
        </div>

        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class:list={[
              "inline-block rounded-full px-2 py-0.5 text-xs font-sans font-medium",
              project.data.status === "active"
                ? "bg-nord-green/10 text-nord-green"
                : project.data.status === "completed"
                  ? "bg-nord-frost1/10 text-nord-frost1 dark:text-nord-frost3"
                  : "bg-gray-100 text-gray-500 dark:bg-dark-card dark:text-dark-muted",
            ]}>
              {project.data.status}
            </span>
          </div>

          <h2 class="font-sans text-lg font-semibold text-gray-900 dark:text-dark-text
                     group-hover:text-nord-frost1 dark:group-hover:text-nord-frost3 transition-colors">
            {project.data.title}
          </h2>

          <p class="mt-1 text-sm text-gray-600 dark:text-dark-muted line-clamp-2">
            {project.data.summary}
          </p>

          <div class="mt-3 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag: string) => (
              <span class="rounded bg-surface-secondary px-2 py-0.5 text-xs text-gray-500
                           dark:bg-dark-card dark:text-dark-muted font-sans">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>
