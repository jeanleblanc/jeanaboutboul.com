---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import RightRailToc from "../../components/RightRailToc.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const tocSections = toc.reduce(
  (sections, heading) => {
    if (heading.depth === 2) {
      sections.push({ heading, children: [] });
      return sections;
    }

    const lastSection = sections[sections.length - 1];
    if (lastSection) {
      lastSection.children.push(heading);
    }
    return sections;
  },
  [] as Array<{
    heading: (typeof toc)[number];
    children: Array<(typeof toc)[number]>;
  }>
);
---

<Layout title={project.data.title} description={project.data.summary}>
  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-8">
  <article>
    <!-- Header -->
    <header class="mb-10">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-nord-frost1
               dark:text-dark-muted dark:hover:text-nord-frost3 transition-colors font-sans mb-4"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to Projects
      </a>

      <h1 class="font-sans text-3xl font-bold tracking-tight text-gray-900 dark:text-dark-text">
        {project.data.title}
      </h1>

      <div class="mt-3 flex flex-wrap items-center gap-3">
        <span class:list={[
          "inline-block rounded-full px-2.5 py-0.5 text-xs font-sans font-medium",
          project.data.status === "active"
            ? "bg-nord-green/10 text-nord-green"
            : "bg-nord-frost1/10 text-nord-frost1 dark:text-nord-frost3",
        ]}>
          {project.data.status}
        </span>
        <time class="text-sm text-gray-400 dark:text-gray-500 font-sans">
          {project.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
          })}
        </time>
      </div>

      <p class="mt-4 whitespace-pre-line text-gray-600 dark:text-dark-muted leading-relaxed">
        {project.data.summary}
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        {project.data.tags.map((tag: string) => (
          <span class="rounded bg-surface-secondary px-2.5 py-1 text-xs text-gray-500
                       dark:bg-dark-card dark:text-dark-muted font-sans">
            {tag}
          </span>
        ))}
      </div>

      <div class="mt-6 h-px bg-gradient-to-r from-nord-frost1 via-nord-green to-transparent"></div>
    </header>

    {/* Table of Contents */}
    {tocSections.length > 0 && (
      <nav
        class="mb-10 rounded-xl border border-surface-secondary/80 bg-white/70 p-5 lg:hidden
               shadow-sm backdrop-blur-sm dark:border-dark-card dark:bg-dark-secondary/60"
        aria-label="Table of contents"
      >
        <details class="group" open>
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3
                   rounded-lg px-2 py-1.5 font-sans text-xs font-semibold uppercase
                   tracking-widest text-gray-500 transition-colors hover:text-nord-frost1
                   dark:text-gray-400 dark:hover:text-nord-frost3"
          >
            <span>Table of Contents</span>
            <svg
              class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180 dark:text-gray-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25L12 15.75 4.5 8.25" />
            </svg>
          </summary>

          <ol class="mt-4 space-y-3 list-none">
            {tocSections.map((section, sectionIndex) => (
              <li class="rounded-lg border border-surface-secondary/70 bg-white/70 dark:border-dark-card dark:bg-dark-secondary/80">
                <details class="group" open>
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-2 px-3 py-2">
                    <span class="flex items-start gap-2 text-sm font-sans font-medium text-gray-700 dark:text-dark-text">
                      <span class="mt-0.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-nord-frost1/15 px-1.5 text-[11px] font-semibold text-nord-frost1 dark:bg-nord-frost3/20 dark:text-nord-frost3">
                        {sectionIndex + 1}
                      </span>
                      <span>{section.heading.text}</span>
                    </span>
                    <svg
                      class="mt-0.5 h-4 w-4 text-gray-400 transition-transform group-open:rotate-180 dark:text-gray-500"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25L12 15.75 4.5 8.25" />
                    </svg>
                  </summary>

                  <div class="px-3 pb-2">
                    <a
                      href={`#${section.heading.slug}`}
                      class="inline-flex text-xs font-sans font-medium text-nord-frost1 hover:text-nord-frost2 dark:text-nord-frost3 dark:hover:text-nord-frost4"
                    >
                      Go to section
                    </a>

                    {section.children.length > 0 && (
                      <ol class="mt-2 space-y-1 pl-4 list-none border-l border-surface-secondary dark:border-dark-card">
                        {section.children.map((child) => (
                          <li>
                            <a
                              href={`#${child.slug}`}
                              class="text-sm font-sans text-gray-500 transition-colors
                                     hover:text-nord-frost1 dark:text-dark-muted
                                     dark:hover:text-nord-frost3"
                            >
                              {child.text}
                            </a>
                          </li>
                        ))}
                      </ol>
                    )}
                  </div>
                </details>
              </li>
            ))}
          </ol>
        </details>
      </nav>
    )}

    <!-- Content -->
    <div class="rounded-xl border border-surface-secondary/80 bg-white/70 px-5 py-6 shadow-sm backdrop-blur-sm dark:border-dark-card dark:bg-dark-secondary/40 md:px-8 md:py-8">
      <div class="prose prose-lg dark:prose-nord max-w-none">
        <Content />
      </div>
    </div>
  </article>
  {tocSections.length > 0 && <RightRailToc tocSections={tocSections} />}
  </div>
</Layout>
