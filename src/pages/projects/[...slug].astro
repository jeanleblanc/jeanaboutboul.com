---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import RightRailToc from "../../components/RightRailToc.astro";
import { formatMonthYear } from "../../utils/content";
import { buildTocSections } from "../../utils/toc";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const tocSections = buildTocSections(headings);
---

<Layout title={project.data.title} description={project.data.summary}>
  <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-8">
    <article>
      <header class="mb-10">
        <a
          href="/projects"
          class="font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-faint hover:text-accent"
        >
          Back to Projects
        </a>

        <time class="mt-6 block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
          {formatMonthYear(project.data.date)}
        </time>

        <h1 class="mt-4 max-w-4xl text-4xl font-bold tracking-tight text-ink sm:text-5xl">
          {project.data.title}
        </h1>

        <p class="mt-6 max-w-3xl whitespace-pre-line text-lg leading-relaxed text-ink-soft">
          {project.data.summary}
        </p>

        <div class="tag-list mt-6">
          {project.data.tags.map((tag: string) => (
            <span class="tag-chip">
              {tag}
            </span>
          ))}
        </div>
      </header>

      {tocSections.length > 0 && (
        <nav class="surface-card mb-8 p-5 lg:hidden" aria-label="Table of contents">
          <details class="group" open>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 font-sans text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-faint transition-colors hover:text-accent">
              <span>On this page</span>
              <svg
                class="h-4 w-4 text-ink-faint transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25L12 15.75 4.5 8.25" />
              </svg>
            </summary>

            <ol class="mt-4 space-y-3 list-none">
              {tocSections.map((section, sectionIndex) => (
                <li>
                  <a
                    href={`#${section.heading.slug}`}
                    class="block text-sm font-sans font-medium text-ink transition-colors hover:text-accent"
                  >
                    {sectionIndex + 1}. {section.heading.text}
                  </a>

                  {section.children.length > 0 && (
                    <ol class="mt-2 space-y-1 pl-4 list-none">
                      {section.children.map((child) => (
                        <li>
                          <a
                            href={`#${child.slug}`}
                            class="text-xs font-sans uppercase tracking-[0.14em] text-ink-faint transition-colors hover:text-accent"
                          >
                            {child.text}
                          </a>
                        </li>
                      ))}
                    </ol>
                  )}
                </li>
              ))}
            </ol>
          </details>
        </nav>
      )}

      <div class="reading-panel">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </div>
    </article>
    {tocSections.length > 0 && <RightRailToc tocSections={tocSections} />}
  </div>
</Layout>
