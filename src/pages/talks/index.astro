---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const talks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [...new Set(talks.map((t) => t.data.category))];
---

<Layout title="Talks & Notes" description="Lectures, notes, and articles">
  <section class="max-w-6xl">
    <h1 class="page-title">Talks & Notes</h1>

    <div class="mt-8 space-y-4">
      <div>
        <label
          for="search-input"
          class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint"
        >
          Search
        </label>
        <input
          id="search-input"
          type="text"
          placeholder="Search talks and notes"
          class="mt-2 w-full max-w-xl border border-line bg-paper-raised px-4 py-3 font-sans text-base text-ink placeholder:text-ink-faint focus:border-line-strong focus:outline-none"
        />
      </div>

      <div class="flex flex-wrap gap-2">
        <button
          class="filter-btn border border-line bg-paper-raised px-3 py-1.5 font-sans text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-soft transition-colors hover:border-line-strong hover:text-ink"
          data-category="all"
        >
          All
        </button>
        {categories.map((cat) => (
          <button
            class="filter-btn border border-line bg-paper-raised px-3 py-1.5 font-sans text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-soft transition-colors hover:border-line-strong hover:text-ink"
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div id="talks-list" class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {talks.map((talk) => (
        <a
          href={`/talks/${talk.id}`}
          class="talk-item surface-card block p-5 transition-colors hover:border-line-strong"
          data-title={talk.data.title.toLowerCase()}
          data-summary={talk.data.summary.toLowerCase()}
          data-category={talk.data.category}
          data-tags={talk.data.tags.join(" ").toLowerCase()}
        >
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
            <span class="text-accent">{talk.data.category}</span>
            <time>
              {talk.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
          </div>

          <h2 class="mt-4 text-2xl font-bold tracking-tight text-ink">
            {talk.data.title}
          </h2>

          {talk.data.venue && (
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">
              {talk.data.venue}
            </p>
          )}

          <p class="mt-4 font-sans text-[0.68rem] uppercase tracking-[0.16em] text-ink-faint">
            {talk.data.tags.join(" · ")}
          </p>
        </a>
      ))}
    </div>

    <p
      id="no-results"
      class="hidden mt-8 font-sans text-[0.72rem] uppercase tracking-[0.18em] text-ink-faint"
    >
      No talks or notes match your search.
    </p>
  </section>

  <script>
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const talkItems = document.querySelectorAll(".talk-item") as NodeListOf<HTMLElement>;
    const filterBtns = document.querySelectorAll(".filter-btn") as NodeListOf<HTMLButtonElement>;
    const noResults = document.getElementById("no-results");

    let activeCategory = "all";

    function filterTalks() {
      const query = searchInput.value.toLowerCase().trim();
      let visible = 0;

      talkItems.forEach((item) => {
        const title = item.dataset.title || "";
        const summary = item.dataset.summary || "";
        const category = item.dataset.category || "";
        const tags = item.dataset.tags || "";

        const matchesSearch =
          !query ||
          title.includes(query) ||
          summary.includes(query) ||
          tags.includes(query);

        const matchesCategory =
          activeCategory === "all" || category === activeCategory;

        if (matchesSearch && matchesCategory) {
          item.style.display = "";
          visible += 1;
        } else {
          item.style.display = "none";
        }
      });

      if (noResults) {
        noResults.classList.toggle("hidden", visible > 0);
      }
    }

    searchInput?.addEventListener("input", filterTalks);

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterBtns.forEach((b) => b.classList.remove("active", "!border-accent", "!text-accent"));
        btn.classList.add("active", "!border-accent", "!text-accent");
        activeCategory = btn.dataset.category || "all";
        filterTalks();
      });
    });

    filterBtns[0]?.classList.add("!border-accent", "!text-accent");
  </script>
</Layout>
