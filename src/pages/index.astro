---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const allTalks = await getCollection("talks");

// Pick 1 random project and 2 random talks
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const randomProject = shuffle(allProjects).slice(0, 1);
const randomTalks = shuffle(allTalks).slice(0, 2);
---

<Layout title="Jean Aboutboul">
  <!-- ═══ Hero ═══ -->
  <section class="mb-16">
    <div class="relative">
      <!-- Decorative accent line -->
      <div
        class="absolute -left-6 top-0 h-full w-px bg-gradient-to-b from-nord-frost1 via-nord-green to-transparent"
      ></div>

      <h1 class="font-sans text-4xl font-bold tracking-tight text-gray-900 dark:text-dark-text sm:text-5xl">
        Hello, I'm
        <span class="text-nord-frost1 dark:text-nord-frost3">Jean Aboutboul</span>.
      </h1>

      <p class="mt-6 text-lg leading-relaxed text-gray-600 dark:text-dark-muted max-w-2xl">
        I'm a microengineering student at EPFL interested in
        <span class="text-nord-frost1 dark:text-nord-frost3">robotics</span>,
        <span class="text-nord-green">embedded systems</span>, and
        <span class="text-nord-frost4 dark:text-nord-frost4">low-level software</span>.
        This site is a collection of my projects, notes, and talks.
      </p>

      <div class="mt-8 flex gap-4">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 rounded-lg bg-nord-frost1 px-5 py-2.5
                 text-sm font-sans font-medium text-white shadow-sm
                 hover:bg-nord-frost2 transition-colors"
        >
          View Projects
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="/talks"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-300
                 px-5 py-2.5 text-sm font-sans font-medium text-gray-700
                 hover:bg-surface-secondary transition-colors
                 dark:border-dark-card dark:text-dark-muted dark:hover:bg-dark-secondary"
        >
          Read Notes
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ Dashboard ═══ -->
  <section>
    <h2 class="font-sans text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-6">
      Recent Work
    </h2>

    <div class="space-y-6">
      <!-- Featured Project -->
      {randomProject.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="group block rounded-xl border border-surface-secondary bg-white p-6
                 shadow-sm transition-all hover:shadow-md hover:border-nord-frost1/30
                 dark:border-dark-card dark:bg-dark-secondary dark:hover:border-nord-frost1/30"
        >
          <div class="flex items-start justify-between">
            <div>
              <span class="inline-block rounded-full bg-nord-frost1/10 px-2.5 py-0.5
                           text-xs font-sans font-medium text-nord-frost1
                           dark:bg-nord-frost1/20 dark:text-nord-frost3 mb-2">
                Project
              </span>
              <h3 class="font-sans text-lg font-semibold text-gray-900 dark:text-dark-text
                         group-hover:text-nord-frost1 dark:group-hover:text-nord-frost3 transition-colors">
                {project.data.title}
              </h3>
              <p class="mt-1 text-sm text-gray-600 dark:text-dark-muted">
                {project.data.summary}
              </p>
            </div>
            <svg
              class="h-5 w-5 flex-shrink-0 text-gray-400 group-hover:text-nord-frost1
                     dark:group-hover:text-nord-frost3 transition-colors mt-1"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <span class="rounded bg-surface-secondary px-2 py-0.5 text-xs text-gray-500
                           dark:bg-dark-card dark:text-dark-muted font-sans">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}

      <!-- Featured Talks -->
      <div class="grid gap-4 sm:grid-cols-2">
        {randomTalks.map((talk) => (
          <a
            href={`/talks/${talk.id}`}
            class="group block rounded-xl border border-surface-secondary bg-white p-5
                   shadow-sm transition-all hover:shadow-md hover:border-nord-green/30
                   dark:border-dark-card dark:bg-dark-secondary dark:hover:border-nord-green/30"
          >
            <span class="inline-block rounded-full bg-nord-green/10 px-2.5 py-0.5
                         text-xs font-sans font-medium text-nord-green mb-2">
              {talk.data.category}
            </span>
            <h3 class="font-sans text-base font-semibold text-gray-900 dark:text-dark-text
                       group-hover:text-nord-green transition-colors">
              {talk.data.title}
            </h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-dark-muted line-clamp-2">
              {talk.data.summary}
            </p>
            <time class="mt-2 block text-xs text-gray-400 dark:text-gray-500 font-sans">
              {talk.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
