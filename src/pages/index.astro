---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatSemesterOrMonth, getTalkCategoryLabel, isEpflTalk } from "../utils/content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const allTalks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentProject = allProjects.slice(0, 1);
const recentTalks = allTalks.slice(0, 2);
---

<Layout title="Jean Aboutboul">
  <section class="grid gap-12 lg:grid-cols-[minmax(0,1.7fr)_15rem] lg:items-start">
    <div>
      <h1 class="max-w-4xl text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        &ldquo;The Analytical Engine weaves algebraic patterns just as the Jacquard loom
        weaves flowers and leaves. - Ada Lovelace&rdquo; - Jean Aboutboul
      </h1>

      <p class="mt-6 max-w-3xl text-xl leading-relaxed text-ink-soft">
        I&rsquo;m a microengineering student at EPFL interested in robotics, astronomy,
        embedded systems, and low-level software. This site is a quiet archive of projects,
        talks, and technical notes.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/projects" class="button-primary">
          View projects
        </a>
        <a href="/talks" class="button-secondary">
          Read notes
        </a>
      </div>
    </div>

    <dl class="space-y-6 border-l border-line pl-6 pt-1 font-sans">
      <div class="space-y-2">
        <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">Current focus</dt>
        <dd class="text-sm leading-relaxed text-ink-soft">
          Robotics, control, embedded electronics, and technical communication.
        </dd>
      </div>

      <div class="space-y-2">
        <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">Interests</dt>
        <dd class="text-sm leading-relaxed text-ink-soft">Music, philosophy.</dd>
      </div>

      <div class="space-y-2">
        <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">Studying</dt>
        <dd class="text-sm leading-relaxed text-ink-soft">BSc Microengineering, EPFL.</dd>
      </div>

      <div class="space-y-2">
        <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">Based in</dt>
        <dd class="text-sm leading-relaxed text-ink-soft">Lausanne, Switzerland.</dd>
      </div>

      <div class="space-y-2">
        <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">Elsewhere</dt>
        <dd class="space-y-1 text-sm leading-relaxed text-ink-soft">
          <p>
            <a href="mailto:jeanaboutboul@gmail.com" class="hover:text-accent">
              jeanaboutboul@gmail.com
            </a>
          </p>
          <p>
            <a href="https://github.com/AboutJean" class="hover:text-accent">GitHub</a>
            {" / "}
            <a href="https://www.linkedin.com/in/jean-aboutboul" class="hover:text-accent">
              LinkedIn
            </a>
          </p>
        </dd>
      </div>
    </dl>
  </section>

  <section class="mt-16 grid gap-8 pt-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.9fr)]">
    <div>
      <p class="kicker">Recent project</p>
      <div class="mt-4 border-y border-line py-4">
        {recentProject.map((project) => (
          <a href={`/projects/${project.id}`} class="interactive-card card-padding-lg">
            <h2 class="text-3xl font-bold tracking-tight text-ink">{project.data.title}</h2>
            <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-soft">
              {project.data.summary}
            </p>
            <div class="tag-list mt-5">
              {project.data.tags.map((tag: string) => (
                <span class="tag-chip">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>

    <div>
      <div class="flex items-baseline justify-between gap-4">
        <p class="kicker">Recent notes</p>
        <a
          href="/talks"
          class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint hover:text-accent"
        >
          All notes
        </a>
      </div>

      <div class="mt-4 border-y border-line py-4">
        <div class="grid gap-4">
          {recentTalks.map((talk) => (
            <a href={`/talks/${talk.id}`} class="interactive-card card-padding">
              <p class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-accent">
                {getTalkCategoryLabel(talk)}
              </p>
              <h3 class="mt-3 text-2xl font-bold tracking-tight text-ink">{talk.data.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">
                {talk.data.summary}
              </p>
              <time class="mt-4 block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
                {formatSemesterOrMonth(talk.data.date, isEpflTalk(talk))}
              </time>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
