---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — Jean Aboutboul" description="Get in touch">
  <div class="flex min-h-[70vh] items-center">
    <div class="mx-auto w-full">
      <div
        class="contact-business-card mx-auto w-full max-w-lg border border-zinc-300 bg-white px-8 py-7 text-zinc-900 shadow-[0_18px_36px_rgba(15,15,15,0.05)] sm:px-10 sm:py-8"
        style="aspect-ratio: 7 / 4;"
      >
        <div class="flex h-full flex-col">
          <div class="flex items-start justify-between gap-4 text-[11px] text-zinc-700">
            <a
              href="mailto:jeanaboutboul@gmail.com"
              class="business-card-copy leading-none tracking-[0.14em] text-zinc-700"
            >
              jeanaboutboul@gmail.com
            </a>

            <div class="flex items-center gap-4">
              <a
                href="https://github.com/AboutJean"
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-700 transition-opacity hover:opacity-70"
                aria-label="GitHub"
              >
                <svg class="h-[16px] w-[16px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
              </a>

              <a
                href="https://www.linkedin.com/in/jean-aboutboul"
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-700 transition-opacity hover:opacity-70"
                aria-label="LinkedIn"
              >
                <svg class="h-[16px] w-[16px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>

              <a
                href="https://people.epfl.ch/jean.aboutboul"
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-700 transition-opacity hover:opacity-70"
                aria-label="EPFL"
              >
                <svg class="h-[16px] w-[16px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z" />
                </svg>
              </a>
            </div>
          </div>

          <div class="flex flex-1 flex-col items-center justify-center text-center">
            <h1 class="business-card-copy text-[1.8rem] leading-none tracking-[0.16em] text-zinc-900 sm:text-[2rem]">
              Jean Aboutboul
            </h1>

            <p class="business-card-copy mt-3 text-[1rem] leading-none tracking-[0.12em] text-zinc-700 sm:text-[1.05rem]">
              Microengineering Student &middot; EPFL
            </p>
          </div>

          <p class="business-card-copy text-center text-[0.9rem] leading-none tracking-[0.12em] text-zinc-600">
            Lausanne, Switzerland
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
